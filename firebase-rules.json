{
  "rules": {
    /* 🛡️ ARGON MEDICAL OS — Security Rules v4.0 */
    ".read": false,
    ".write": false,

    "super_admin": {
      ".read": true,
      ".write": true
    },

    "clinics": {
      "$clinicId": {
        "settings": {
          ".read": true,
          ".write": true,
          "passwords": {
            ".read": false,
            ".write": true
          }
        },
        "patients": {
          ".read": true,
          ".write": true,
          "$patientId": {
            ".validate": "newData.hasChildren(['name', 'phone'])"
          }
        },
        "appointments": {
          ".read": true,
          ".write": true,
          "$appointmentId": {
            ".validate": "newData.hasChildren(['patientId', 'date', 'status'])"
          }
        },
        "prescriptions": {
          ".read": true,
          ".write": true
        },
        "pharmacy_inventory": {
          ".read": true,
          ".write": true
        },
        "lab_requests": {
          ".read": true,
          ".write": true
        },
        "lab_results": {
          ".read": true,
          ".write": true
        },
        "radiology_requests": {
          ".read": true,
          ".write": true
        },
        "radiology_results": {
          ".read": true,
          ".write": true
        },
        "invoices": {
          ".read": true,
          ".write": true
        },
        "whatsapp_queue": {
          ".read": true,
          ".write": true
        },
        "whatsapp_settings": {
          ".read": true,
          ".write": true
        },
        "audit_logs": {
          ".read": true,
          ".write": true
        },
        "waiting_room": {
          ".read": true,
          ".write": true
        }
      }
    },

    "restaurants": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    }
  }
}
