{
  "rules": {
    /* 🛡️ ARGON MEDICAL OS — Security Rules v4.0 */
    ".read": false,
    ".write": false,

    "super_admin": {
      ".read": true,
      ".write": true
    },

    "clinics": {
      "$clinicId": {
        "settings": {
          ".read": true,
          ".write": true,
          "passwords": {
            ".read": false,
            ".write": true
          }
        },
        "patient_identity": {
          ".read": true,
          ".write": true,
          "$patientId": {
            // Enterprise Rule: UUID must be generated (starts with '-')
            ".validate": "$patientId.beginsWith('-') && newData.hasChildren(['name', 'phone'])"
          }
        },
        "patient_records": {
          ".read": true,
          ".write": true
        },
        "patient_timeline": {
          ".read": true,
          // Enterprise Immutability: Allow write, but prevent edits/deletes if event already exists
          ".write": true,
          "$patientId": {
             "$eventId": {
               ".write": "!data.exists() || !newData.exists()" // Allows append and soft delete but restricts direct modification
             }
          }
        },
        "patient_indexes": {
          ".read": true,
          ".write": true
        },
        "patient_attachments": {
          ".read": true,
          ".write": true
        },
        "profile_versions": {
          ".read": true,
          ".write": true
        },
        "appointments": {
          ".read": true,
          ".write": true,
          "$appointmentId": {
            ".validate": "newData.hasChildren(['patientId', 'date', 'status'])"
          }
        },
        "prescriptions": {
          ".read": true,
          ".write": true
        },
        "pharmacy_inventory": {
          ".read": true,
          ".write": true
        },
        "lab_requests": {
          ".read": true,
          ".write": true
        },
        "lab_results": {
          ".read": true,
          ".write": true
        },
        "radiology_requests": {
          ".read": true,
          ".write": true
        },
        "radiology_results": {
          ".read": true,
          ".write": true
        },
        "invoices": {
          ".read": true,
          ".write": true
        },
        "whatsapp_queue": {
          ".read": true,
          ".write": true
        },
        "whatsapp_settings": {
          ".read": true,
          ".write": true
        },
        "audit_logs": {
          ".read": true,
          ".write": true
        },
        "waiting_room": {
          ".read": true,
          ".write": true
        }
      }
    },

    "restaurants": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    }
  }
}
