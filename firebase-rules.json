{
  "rules": {
    /* 🛡️ ARGON SYSTEM CORE SECURITY RULES v3.0 */
    ".read": false,
    ".write": false,

    "super_admin": {
      /* Only the super admin interface should access this. 
         Ideally, this would be restricted to a specific Auth UID. 
         For now, we keep it highly restricted. */
      ".read": true, 
      ".write": true
    },

    "restaurants": {
      "$restaurantId": {
        "settings": {
          ".read": true,
          /* Only allow status and acceptOrders to be public-read for the menu */
          ".write": true, 
          "password": {
            ".read": false,
            ".write": true
          }
        },
        "products": {
          ".read": true,
          ".write": true
        },
        "orders": {
          ".read": true,
          ".write": true,
          "$orderId": {
            /* Basic validation for incoming orders */
            ".validate": "newData.hasChildren(['custName', 'custPhone', 'items', 'total'])"
          }
        },
        "completedOrders": {
          ".read": true,
          ".write": true
        }
      }
    }
  }
}
